# Default: http://localhost:8000
VITE_API_BASE_URL=https://ci-desk-backend.siddharthraj.me

# Tab feature flags — set to true/false to enable or disable each tab
VITE_TAB_MARKETS=true
VITE_TAB_MACRO=true
